# Stardust environment — all variables are OPTIONAL.
# Stardust needs no API keys: astronomy runs in the browser and the geocoding
# API is keyless. Copy this file to `.env` only if you want to override a default.

# Override the city-geocoding endpoint (defaults to Open-Meteo's free service).
# Must be an Open-Meteo-compatible /v1/search endpoint.
# VITE_GEOCODING_ENDPOINT=https://geocoding-api.open-meteo.com/v1/search
